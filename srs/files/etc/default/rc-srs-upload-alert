## RC SRS upload alert (Telegram)
## Fill TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID to enable notifications.
##
## Example:
## TELEGRAM_BOT_TOKEN=123456:ABCDEF...
## TELEGRAM_CHAT_ID=-1001234567890
##

# Local SRS HTTP API
SRS_API_URL=http://127.0.0.1:1985/api/v1

# Alert when remote publisher count is below this.
MIN_PUBLISHERS=1

# Require N consecutive failures (minutes) before alerting DOWN.
FAIL_THRESHOLD=2

# Telegram
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: paths
STATE_FILE=/var/lib/rc-srs-upload-alert/state.env
LOG_FILE=/var/log/rc-srs-upload-alert.log

